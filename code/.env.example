# ============================================================
# .env.example — Copy this file to .env and fill in your keys
# ============================================================
# IMPORTANT: Never commit .env to version control.
#            Only .env.example is tracked in git.
# ============================================================

# Web of Science (WoS) Starter API key
# Obtain from: https://developer.clarivate.com/apis/wos-starter
WOS_API_KEY=your_wos_api_key_here

# SerpAPI key (used for Google Scholar extraction)
# Obtain from: https://serpapi.com/dashboard
# Account: avdresearch@marshall.usc.edu
SERPAPI_KEY=your_serpapi_key_here
